NODE_ENV=development
PORT=5000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=easyphones

# JWT
JWT_ACCESS_SECRET=your_access_secret_at_least_256_bits_long_here
JWT_REFRESH_SECRET=your_refresh_secret_at_least_256_bits_long_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS
FRONTEND_URL=http://localhost:3000

# File uploads (stored as blobs in DB — no external storage)
MAX_FILE_SIZE_MB=5
